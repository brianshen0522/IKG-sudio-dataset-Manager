# IKG Studio Dataset Manager
# Copy to .env and adjust for your environment.

# Required: JWT signing secret used for login sessions.
# Generate one with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret

# PostgreSQL connection string.
# Note: Docker Compose hardcodes this internally — only needed here for running
# scripts locally (e.g. scripts/migrate-to-datasets.js).
DATABASE_URL=postgresql://studio:studio@postgres:5432/datasets_manager

# Initial password for the seeded admin account.
# Username is always: admin
INITIAL_ADMIN_PASSWORD=admin

# Base path that contains datasets.
DATASET_BASE_PATH=/data/datasets

# Public address users use to reach the app (used by Caddy and internal config).
# Examples: localhost, 192.168.1.100, myserver.local
PUBLIC_ADDRESS=localhost

# Next.js manager UI/API port.
MANAGER_PORT=3000

# Default duplicate detection threshold for new datasets.
DEFAULT_IOU_THRESHOLD=0.8

# Default duplicate-debug mode for new datasets.
DEFAULT_DEBUG_MODE=false

# Number of nearby images to preload in the label editor.
LABEL_EDITOR_PRELOAD_COUNT=25

# Max number of concurrent thumbnail loads in Viewer.
VIEWER_IMAGE_LOADING_BATCH_COUNT=200

# Thumbnail JPEG quality, 1-100.
THUMBNAIL_QUALITY=50

# API request logging level: info | debug | silent
API_LOG_LEVEL=info

# Available OBB creation modes exposed in admin settings.
# Valid values: rectangle, 4point
AVAILABLE_OBB_MODES=rectangle,4point

# Duplicate handling rules as a JSON array string.
# Each rule supports:
# - pattern: substring matched against the dataset path
# - action: skip | move | delete
# - labels: 0 means all labels, otherwise a specific label count
# - priority: lower number wins
# Example:
# DUPLICATE_RULES=[{"pattern":"invalid","action":"skip","labels":0,"priority":1}]
DUPLICATE_RULES=

# Fallback duplicate action when no rule matches: skip | move | delete
DUPLICATE_DEFAULT_ACTION=move
